# LifeSupply Command Center — Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit a populated .env file.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (Postgres) — Phase 1+
# Local dev: docker compose postgres OR Neon dev branch
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifesupply_cc?schema=public

# -----------------------------------------------------------------------------
# Auth.js v5 — Phase 1
# Generate AUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=replace-with-random-32-byte-base64-secret
AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Encrypted credential vault — docs/06 §8
# Required for the /admin/integrations UI to store secrets in the DB.
# Generate with: openssl rand -base64 32  (must decode to exactly 32 bytes)
# Without this set, integrations fall back to env vars only.
# -----------------------------------------------------------------------------
MASTER_ENCRYPTION_KEY=replace-with-32-byte-base64-master-key

# -----------------------------------------------------------------------------
# Integration env vars (optional — env wins over the vault when both are set)
# Leave blank in production if you'll manage these from /admin/integrations.
# -----------------------------------------------------------------------------

# BigCommerce
BIGCOMMERCE_STORE_HASH=
BIGCOMMERCE_API_TOKEN=
BIGCOMMERCE_CLIENT_ID=

# QuickBooks Online
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=sandbox

# Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=

# Google Analytics 4
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# File storage (Cloudflare R2 / S3-compatible)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Outbound email — Resend. Required for live investor-update distribution.
# When unset, releaseInvestorUpdate() falls back to the stub path.
RESEND_API_KEY=
INVESTOR_FROM_EMAIL=
INVESTOR_FROM_NAME=LifeSupply

# Audit log retention (days). Default 365, minimum 30.
AUDIT_RETENTION_DAYS=365

# Supplier portal automation (BBM01)
# When unset the Playwright runner hits the in-repo mock portal at
# /dev/mock-portals/bbm01/index.html. Set to the live URL in production.
# Browsers must be installed once per host: pnpm exec playwright install chromium
SUPPLIER_PORTAL_BBM01_URL=

# Optional model overrides (env wins over /admin/ai-settings)
ANTHROPIC_MODEL=
OPENAI_MODEL=
