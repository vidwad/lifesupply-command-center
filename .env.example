# LifeSupply Command Center — Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit a populated .env file.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (Postgres) — Phase 1+
# Local dev: docker compose postgres OR Neon dev branch
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifesupply_cc?schema=public

# -----------------------------------------------------------------------------
# Auth.js v5 — Phase 1
# Generate AUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=replace-with-random-32-byte-base64-secret
AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Integrations — Phase 5+ (placeholders; never populate in committed files)
# -----------------------------------------------------------------------------

# BigCommerce
BIGCOMMERCE_STORE_HASH=
BIGCOMMERCE_API_TOKEN=
BIGCOMMERCE_CLIENT_ID=

# QuickBooks Online
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=sandbox

# Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=

# Google Analytics 4
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# File storage (Cloudflare R2 / S3-compatible)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
