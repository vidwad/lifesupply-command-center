# Per-store BigCommerce API access tokens.
# Get from BigCommerce control panel: Settings > API > Store-level API accounts
# Required scopes: Customers (read-only), Orders (read-only).
# Optional scopes (used by Group G/F enrichers): Carts (read-only), Wishlists (read-only), Information & Settings (read-only).

BC_LIFESUPPLY_ACCESS_TOKEN=
BC_WELLMART_ACCESS_TOKEN=
BC_STORE3_ACCESS_TOKEN=
